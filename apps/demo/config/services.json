          "endpoint": "https://chat-bot-demo-six.vercel.app/api/mock-tools/emission-factor",
          "method": "GET",
          "parameters": {
            "type": "object",
            "properties": {
              "scope": { "type": "string", "description": "배출 Scope (1, 2, 3)", "enum": ["1", "2", "3"] },
              "category": { "type": "string", "description": "배출원 카테고리 (선택, 예: 경유, 전력)" }
            },
            "required": ["scope"]
          }
        },
        {
