        {
          "name": "deleteEmissionRecord",
          "description": "직원의 통근 배출량 데이터를 삭제합니다.",
          "endpoint": "https://chat-bot-demo-six.vercel.app/api/mock-tools/emission-records",
          "method": "POST",
