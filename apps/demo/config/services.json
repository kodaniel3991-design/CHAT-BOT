              "department": { "type": "string", "description": "부서명 (선택, 예: 생산3본부)" },
              "id": { "type": "string", "description": "레코드 ID (선택, 예: ER-001)" }
            }
          }
        },
        {
          "name": "createEmissionRecord",
          "description": "새 직원의 통근 배출량 데이터를 등록합니다.",
          "endpoint": "https://chat-bot-demo-six.vercel.app/api/mock-tools/emission-records",
          "method": "POST",
          "parameters": {
            "type": "object",
