[
  {
    "id": "esg-on",
    "label": "ESG_On",
    "description": "ESG 배출량 산출",
    "config": {
      "projectId": "esg-on",
      "llm": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-20250514",
        "maxTokens": 2048,
        "temperature": 0.3
      },
      "systemPrompt": "당신은 ESG 배출량 산출 SaaS(ESG_On)의 AI 어시스턴트입니다.\n- Scope 1/2/3, 활동자료, 배출계수, 보고서 항목에 대해 안내합니다.\n- 법규·고객사 내부 기준은 확정되지 않은 경우 단정하지 말고 확인 질문을 합니다.\n- 사용자가 배출계수를 물으면 lookupEmissionFactor 도구를 사용하세요.\n- 사용자가 보고서 생성을 요청하면 exportReportDraft 도구를 사용하세요.",
      "conversation": {
        "maxHistoryLength": 12,
        "sessionTimeout": 1800000,
        "historyStrategy": "sliding",
        "welcomeMessage": "안녕하세요. ESG 배출량·활동자료·보고 항목 관련 질문을 도와드릴게요."
      },
      "ui": {
        "theme": "light",
        "botName": "ESG_On 어시스턴트",
        "position": "bottom-left",
        "placeholder": "예: Scope 2 배출계수 조회, 보고서 초안 생성…",
        "allowFileAttachment": true
      },
      "rag": {
        "enabled": true,
        "vectorDbNamespace": "esg-on-docs",
        "topK": 6,
        "minScore": 0.72
      },
      "tools": [
        {
          "name": "lookupEmissionFactor",
          "description": "Scope별 배출계수를 조회합니다. scope(1,2,3)과 category(선택)로 필터링합니다.",
          "endpoint": "http://localhost:3000/api/mock-tools/emission-factor",
          "method": "GET",
          "parameters": {
            "type": "object",
            "properties": {
              "scope": { "type": "string", "description": "배출 Scope (1, 2, 3)", "enum": ["1", "2", "3"] },
              "category": { "type": "string", "description": "배출원 카테고리 (선택, 예: 경유, 전력)" }
            },
            "required": ["scope"]
          }
        },
        {
          "name": "exportReportDraft",
          "description": "ESG 배출량 보고서 초안을 생성합니다.",
          "endpoint": "http://localhost:3000/api/mock-tools/report",
          "method": "POST",
          "parameters": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "보고서 제목" },
              "period": { "type": "string", "description": "보고 기간 (예: 2024-Q4)" }
            },
            "required": ["title", "period"]
          },
          "confirmRequired": true
        }
      ],
      "features": {
        "feedback": true,
        "exportHistory": true,
        "fileAttachment": true,
        "streaming": true
      }
    }
  },
  {
    "id": "mes-on",
    "label": "MES_On",
    "description": "제조 실행",
    "config": {
      "projectId": "mes-on",
      "llm": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-20250514",
        "maxTokens": 2048,
        "temperature": 0.35
      },
      "systemPrompt": "당신은 제조 실행 시스템(MES) SaaS(MES_On)의 AI 어시스턴트입니다.\n- 작업지시, 공정, 설비, 실적·불량·다운타임 조회 흐름을 안내합니다.\n- 실제 설비 제어·데이터 변경은 권한과 확인 절차가 필요함을 안내합니다.\n- 사용자가 작업지시를 물으면 queryWorkOrders 도구를 사용하세요.\n- 사용자가 설비 가동률/OEE를 물으면 queryOeeSnapshot 도구를 사용하세요.",
      "conversation": {
        "maxHistoryLength": 15,
        "sessionTimeout": 2880000,
        "historyStrategy": "sliding",
        "welcomeMessage": "안녕하세요. 생산 실적, 작업지시, 설비 상태 관련 질문을 도와드릴게요."
      },
      "ui": {
        "theme": "auto",
        "botName": "MES_On 어시스턴트",
        "position": "bottom-right",
        "placeholder": "예: 오늘 라인 가동률, 작업지시 상태…",
        "allowFileAttachment": false
      },
      "rag": {
        "enabled": true,
        "vectorDbNamespace": "mes-on-docs",
        "topK": 6,
        "minScore": 0.7
      },
      "tools": [
        {
          "name": "queryWorkOrders",
          "description": "라인별/상태별 작업지시 목록을 조회합니다.",
          "endpoint": "http://localhost:3000/api/mock-tools/work-orders",
          "method": "GET",
          "parameters": {
            "type": "object",
            "properties": {
              "line": { "type": "string", "description": "생산 라인 (예: LINE-A, LINE-B)" },
              "status": { "type": "string", "description": "작업 상태", "enum": ["waiting", "in_progress", "completed"] }
            }
          }
        },
        {
          "name": "queryOeeSnapshot",
          "description": "설비 가동률(OEE) 실시간 스냅샷을 조회합니다.",
          "endpoint": "http://localhost:3000/api/mock-tools/oee-snapshot",
          "method": "GET",
          "parameters": {
            "type": "object",
            "properties": {
              "line": { "type": "string", "description": "라인 필터 (비우면 전체)" }
            }
          }
        }
      ],
      "features": {
        "feedback": true,
        "exportHistory": true,
        "streaming": true
      }
    }
  }
]
