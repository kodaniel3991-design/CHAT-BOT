# true: 클라이언트만 모의 스트리밍
NEXT_PUBLIC_CHAT_USE_MOCK=

# true: API 인증 생략 (로컬 전용)
NEXT_PUBLIC_CHAT_AUTH_DISABLED=

# NextAuth — 프로덕션에서 반드시 설정
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Credentials 데모 비밀번호 (기본: luon-demo)
CHAT_DEMO_PASSWORD=

# 레거시 Bearer JWT (/api/chat 보조) — 선택
CHAT_JWT_SECRET=

CHAT_RATE_LIMIT_PER_MINUTE=30
CHAT_DEMO_TOOL_CONFIRM=

# chat-api 구조화 로그: error | warn | info
LOG_LEVEL=info

# (선택) 채팅 API 공통 베이스 — 비우면 동일 오리진 /api/chat
NEXT_PUBLIC_LUON_CHAT_API_BASE=

# 세션 저장 — 미설정 시 인메모리. 프로덕션·다중 인스턴스는 Upstash 권장
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 서버 전용: 인증 생략 (로컬). NEXT_PUBLIC_CHAT_AUTH_DISABLED 와 별개
CHAT_AUTH_DISABLED=

# 다른 오리진에서 채팅 API 호출 시 — 쉼표 구분, 예: https://app.example.com,http://localhost:5173
CHAT_ALLOWED_ORIGINS=

# ── Supabase PostgreSQL ──
# Supabase > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase RAG (pgvector) ──
# Supabase > Settings > API 에서 복사
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# —— 제품 LLM (하나 이상 설정 시 /api/chat 에서 실제 스트리밍) ——
# Anthropic (config.llm.provider === "anthropic")
ANTHROPIC_API_KEY=
# OpenAI (config.llm.provider === "openai")
OPENAI_API_KEY=
# true: API 키가 있어도 플레이스홀더만 사용 (로컬 테스트)
CHAT_USE_PLACEHOLDER_LLM=
