{
  "name": "@company/chatbot-ui",
  "version": "0.1.0",
  "publishConfig": {
    "access": "restricted"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./styles.css": {
      "default": "./dist/styles/chatbot.css"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src", "package.json"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@company/chatbot-core": "*",
    "@company/chatbot-service-kit": "*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.9",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "~5.6.3",
    "vitest": "^4.1.2"
  }
}
