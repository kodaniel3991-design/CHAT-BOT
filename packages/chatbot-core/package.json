{
  "name": "@company/chatbot-core",
  "version": "0.1.0",
  "publishConfig": {
    "access": "restricted"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist", "src", "package.json"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "~5.6.3",
    "vitest": "^4.1.2"
  }
}
